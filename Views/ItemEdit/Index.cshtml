@using Humanizer
@using ITask7.Models.Inventories
@using Microsoft.AspNetCore.Mvc.TagHelpers
@model ITask7.ViewModels.Inventories.ItemViewModel

@{
    ViewBag.Title = Model.Id == Guid.Empty ? "New Item" : "Edit Item";
    Layout = "_Layout";
    var isNewItem = Model.Id == Guid.Empty;
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">
                <i class="bi @(isNewItem ? "bi-plus-circle" : "bi-pencil-square") me-2"></i>
                @(isNewItem ? "Create New Item" : "Edit Item")
            </h2>
            @if (!isNewItem)
            {
                <small class="text-muted">
                    <i class="bi bi-upc-scan me-1"></i>@Model.CustomId
                </small>
            }
        </div>
        <div class="d-flex gap-2">
            <a href="#" class="btn btn-outline-secondary">
                <i class="bi bi-x-lg me-1"></i>Cancel
            </a>
            <button type="button" id="saveBtn" class="btn btn-primary">
                <i class="bi bi-check-lg me-1"></i>@(isNewItem ? "Create Item" : "Save Changes")
            </button>
        </div>
    </div>

    <!-- Main Form -->
    <form id="itemForm" method="post" action="@Url.Action("SubmitChanges", "ItemEdit")">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id"/>
        <input type="hidden" asp-for="CreatedAt"/>
        <input type="hidden" asp-for="UpdatedAt"/>
        <input type="hidden" asp-for="CreatedByUserName"/>

        <div class="row">
            <!-- Left Column: Metadata -->
            <div class="col-lg-4 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-light">
                        <h5 class="mb-0"><i class="bi bi-info-circle me-2"></i>Information</h5>
                    </div>
                    <div class="card-body">
                        @if (!isNewItem)
                        {
                            <div class="mb-3">
                                <label class="form-label text-muted small mb-1">Item ID</label>
                                <div class="form-control-plaintext fw-mono text-break">@Model.Id</div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label text-muted small mb-1">Custom ID</label>
                                <input type="text" class="form-control" asp-for="CustomId" placeholder="Enter custom identifier"/>
                            </div>

                            <hr class="my-3"/>

                            <div class="mb-2 d-flex justify-content-between">
                                <span class="text-muted small">Created</span>
                                <span class="small">@Model.CreatedAtString by @Model.CreatedByUserName</span>
                            </div>
                            <div class="mb-0 d-flex justify-content-between">
                                <span class="text-muted small">Last Updated</span>
                                <span class="small text-muted">@Model.UpdatedAt.Humanize()</span>
                            </div>
                        }
                        else
                        {
                            <div class="mb-3">
                                <label class="form-label fw-semibold" asp-for="CustomId">Custom ID</label>
                                <input type="text" class="form-control form-control-lg" asp-for="CustomId"
                                       placeholder="Enter a unique identifier" autofocus/>
                                <div class="form-text">Optional custom identifier for this item</div>
                            </div>

                            <div class="alert alert-info d-flex align-items-center mb-0">
                                <i class="bi bi-lightbulb me-2 fs-5"></i>
                                <div class="small">Fill in the custom fields on the right to define your new item.</div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Right Column: Dynamic Fields -->
            <div class="col-lg-8">
                <div class="card shadow-sm">
                    <div class="card-header bg-light d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-ui-checks-grid me-2"></i>Fields</h5>
                        <span class="badge bg-secondary">@Model.FieldDefinitions.Count field(s)</span>
                    </div>
                    <div class="card-body">
                        @if (!Model.FieldDefinitions.Any())
                        {
                            <div class="text-center py-5 text-muted">
                                <i class="bi bi-inbox fs-1 mb-3 d-block"></i>
                                <p>No field definitions available for this item type.</p>
                            </div>
                        }
                        else
                        {
                            <div class="row g-3">
                                @foreach (var fieldDef in Model.FieldDefinitions.OrderBy(f => f.SortOrder))
                                {
                                    var fieldValue = Model.Fields.ContainsKey(fieldDef.Id)
                                        ? Model.Fields[fieldDef.Id]
                                        : null;
                                    var inputName = $"Fields[{fieldDef.Id}]";
                                    var inputId = $"field_{fieldDef.Id}";
                                    var isRequired = fieldDef.IsRequired ? "required" : "";
                                    var requiredMark = fieldDef.IsRequired ? "<span class='text-danger'>*</span>" : "";

                                    <div class="col-md-@(fieldDef.Type == FieldType.MultiLine || fieldDef.Type == FieldType.Document ? "12" : "6")">
                                        <div class="field-wrapper">
                                            <label class="form-label fw-semibold" for="@inputId">
                                                @fieldDef.Title @Html.Raw(requiredMark)
                                                @if (!string.IsNullOrEmpty(fieldDef.Description))
                                                {
                                                    <i class="bi bi-question-circle text-muted ms-1"
                                                       data-bs-toggle="tooltip"
                                                       title="@fieldDef.Description">
                                                    </i>
                                                }
                                            </label>

                                            @switch (fieldDef.Type)
                                            {
                                                case FieldType.SingleLine:
                                                    <input type="text"
                                                           class="form-control"
                                                           id="@inputId"
                                                           name="@inputName"
                                                           value="@(fieldValue?.Value ?? "")"
                                                           @isRequired
                                                           placeholder="Enter @fieldDef.Title.ToLower()"/>
                                                    break;

                                                case FieldType.MultiLine:
                                                    <textarea class="form-control" 
                                                              id="@inputId" 
                                                              name="@inputName" 
                                                              rows="4" 
                                                              @isRequired
                                                              placeholder="Enter @fieldDef.Title.ToLower()">@(fieldValue?.Value ?? "")</textarea>
                                                    break;

                                                case FieldType.Numeric:
                                                    <div class="input-group">
                                                        <span class="input-group-text">
                                                            <i class="bi bi-123"></i>
                                                        </span>
                                                        <input type="number"
                                                               class="form-control"
                                                               id="@inputId"
                                                               name="@inputName"
                                                               value="@(fieldValue?.Value ?? "")"
                                                               @isRequired
                                                               step="any"
                                                               placeholder="0.00"/>
                                                    </div>
                                                    break;

                                                case FieldType.Boolean:
                                                    <div class="form-check form-switch mt-2">
                                                        <input type="hidden" name="@inputName" value="false"/>
                                                        <input class="form-check-input"
                                                               type="checkbox"
                                                               id="@inputId"
                                                               name="@inputName"
                                                               value="true"
                                                               @(fieldValue?.Value?.ToString().ToLower() == "true" ? "checked" : "")/>
                                                        <label class="form-check-label text-muted" for="@inputId">Yes / No</label>
                                                    </div>
                                                    break;

                                                case FieldType.Document:
                                                    <div class="document-field border rounded p-3 bg-light">
                                                        @if (fieldValue?.Value != null)
                                                        {
                                                            <div class="d-flex align-items-center mb-2">
                                                                <i class="bi bi-file-earmark-text fs-4 me-2 text-primary"></i>
                                                                <div class="flex-grow-1">
                                                                    <div class="fw-semibold text-truncate">@fieldValue.Value</div>
                                                                    <small class="text-muted">Previously uploaded document</small>
                                                                </div>
                                                                <button type="button" class="btn btn-sm btn-outline-danger" onclick="clearDocument('@fieldDef.Id')">
                                                                    <i class="bi bi-trash"></i>
                                                                </button>
                                                            </div>
                                                        }
                                                        <input type="file"
                                                               class="form-control"
                                                               id="@inputId"
                                                               name="@(inputName)_file"
                                                               @isRequired
                                                               accept=".pdf,.doc,.docx,.txt,.xls,.xlsx"/>
                                                        <input type="hidden" name="@inputName" id="@(inputId)_value" value="@(fieldValue?.Value ?? "")"/>
                                                        <div class="form-text small mt-1">
                                                            <i class="bi bi-paperclip me-1"></i>PDF, Word, Excel, or Text files
                                                        </div>
                                                    </div>
                                                    break;
                                            }

                                            @if (fieldDef.DisplayInTable)
                                            {
                                                <div class="form-text small">
                                                    <i class="bi bi-table me-1"></i>Displayed in list view
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<!-- Toast Container for Notifications -->
<div class="toast-container position-fixed top-0 end-0 p-3">
    <div id="saveToast" class="toast align-items-center text-white bg-success border-0" role="alert">
        <div class="d-flex">
            <div class="toast-body">
                <i class="bi bi-check-circle me-2"></i>
                <span id="toastMessage">Changes saved successfully!</span>
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Initialize tooltips
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl);
            });

            // Form submission
            $('#saveBtn').on('click', function(e) {
                e.preventDefault();
                
                var $btn = $(this);
                var originalText = $btn.html();
                
                // Validate required fields
                var isValid = true;
                var firstInvalid = null;
                
                $('input[required], textarea[required], select[required]').each(function() {
                    if (!$(this).val()) {
                        isValid = false;
                        $(this).addClass('is-invalid');
                        if (!firstInvalid) firstInvalid = $(this);
                    } else {
                        $(this).removeClass('is-invalid');
                    }
                });

                if (!isValid) {
                    if (firstInvalid) {
                        firstInvalid.focus();
                        $('html, body').animate({
                            scrollTop: firstInvalid.offset().top - 100
                        }, 300);
                    }
                    return;
                }

                // Show loading state
                $btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2"></span>Saving...');

                // Prepare form data
                var formData = new FormData($('#itemForm')[0]);

                $.ajax({
                    url: $('#itemForm').attr('action'),
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function(response) {
                        if (response === true || response.success === true) {
                            // Show success toast
                            var toast = new bootstrap.Toast($('#saveToast')[0]);
                            $('#toastMessage').text('@(isNewItem ? "Item created successfully!" : "Changes saved successfully!")');
                            toast.show();

                            // Redirect after short delay for new items
                            @if (isNewItem)
                            {
                                <text>
                                setTimeout(function() {
                                    window.location.href = '#';
                                }, 1500);
                                </text>
                            }
                            else
                            {
                                <text>
                                $btn.prop('disabled', false).html(originalText);
                                </text>
                            }
                        } else {
                            alert('Failed to save changes. Please try again.');
                            $btn.prop('disabled', false).html(originalText);
                        }
                    },
                    error: function(xhr, status, error) {
                        console.error('Error:', error);
                        alert('An error occurred while saving. Please check your connection and try again.');
                        $btn.prop('disabled', false).html(originalText);
                    }
                });
            });

            // Remove invalid class on input
            $('input, textarea, select').on('input change', function() {
                $(this).removeClass('is-invalid');
            });
        });

        // Clear document field
        function clearDocument(fieldId) {
            $('#field_' + fieldId + '_value').val('');
            $('#field_' + fieldId).closest('.document-field').find('.d-flex').fadeOut(function() {
                $(this).remove();
            });
        }
    </script>
}

<style>
        .fw-mono {
            font-family: 'Courier New', monospace;
            font-size: 0.85rem;
        }
        
        .field-wrapper {
            transition: all 0.2s ease;
        }
        
        .field-wrapper:focus-within {
            transform: translateY(-2px);
        }
        
        .form-control:focus, .form-select:focus {
            box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15);
        }
        
        .is-invalid {
            border-color: #dc3545;
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 12 12' width='12' height='12' fill='none' stroke='%23dc3545'%3e%3ccircle cx='6' cy='6' r='4.5'/%3e%3cpath stroke-linejoin='round' d='M5.8 3.6h.4L6 6.5z'/%3e%3ccircle cx='6' cy='8.2' r='.6' fill='%23dc3545' stroke='none'/%3e%3c/svg%3e");
            background-repeat: no-repeat;
            background-position: right calc(0.375em + 0.1875rem) center;
            background-size: calc(0.75em + 0.375rem) calc(0.75em + 0.375rem);
        }
        
        .document-field {
            transition: all 0.2s ease;
        }
        
        .document-field:hover {
            border-color: #0d6efd !important;
        }
    </style>