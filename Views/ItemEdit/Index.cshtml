@using ITask7.Models.Inventories
@using ITask7.ViewModels.Inventories
@using Microsoft.AspNetCore.Mvc.TagHelpers
@using Humanizer
@using ITask7.Models.CustomId
@model ITask7.ViewModels.Inventories.ItemViewModel

@{
    ViewBag.Title = Model.Id == Guid.Empty ? "New Item" : "Edit Item";
    Layout = "_Layout";
    bool isNewItem = Model.Id == Guid.Empty;
    string inventoryUrl = Url.Action("Index", "InventoryEdit", new { inventoryId = Model.InventoryId }) ?? "#";
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">
                <i class="bi bi-box-seam me-2"></i>
                @(isNewItem ? "Create New Item" : "Edit Item")
            </h2>
            @if (!isNewItem)
            {
                <small class="text-muted">
                    <i class="bi bi-clock-history me-1"></i>
                    Created @Model.CreatedAtString by @Model.CreatedByUserName
                </small>
            }
        </div>
        <div class="btn-group">
            <a href="@inventoryUrl" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Back
            </a>
            <button type="button" id="saveBtn" class="btn btn-primary">
                <i class="bi bi-check-lg me-1"></i>@(isNewItem ? "Create" : "Save Changes")
            </button>
        </div>
    </div>

<form id="itemForm" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id"/>
    <input type="hidden" asp-for="CreatedAt"/>
    <input type="hidden" asp-for="UpdatedAt"/>

    <div class="row">
        <!-- Main Content -->
        <div class="col-lg-8">
            <!-- System Fields Card -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-3"><i class="bi bi-info-circle me-2"></i>Custom Id</h5>
                    <div class="d-flex gap-3 small">
                        <div class="text-muted">
                            <span class="text-uppercase fw-bold" style="font-size: 0.7rem; letter-spacing: 0.05em;">Current</span>
                            <div class="font-monospace text-dark">@Model.CustomId.ToPrintString()</div>
                        </div>
                        <div class="vr"></div>
                        <div>
                            <span class="text-uppercase fw-bold text-primary" style="font-size: 0.7rem; letter-spacing: 0.05em;">New</span>
                            <div id="new-id-label" class="font-monospace text-primary">—</div>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div id="custom-id-editor" class="row g-3 align-items-end">
                            @for (int i = 0; i < Model.CustomId.Schema.Elements.Count; i++)
                            {
                                IdElement element = Model.CustomId.Schema.Elements[i];
                                string elementValue = Model.CustomId.Values[i];
                                bool isReadOnly = !element.IsEditableValue;
                                bool isFixed = element.Type == IdElementType.Fixed;

                                <div class="col-sm-6 col-lg-1 custom-id-row" style="min-width: 200px; max-width: 500px;">
                                    <small class="text-muted d-block mb-1">@element.GetLabel()</small>

                                    <input type="hidden" name="CustomId.Elements[@i].Key.Type" value="@((int)element.Type)"/>
                                    <input type="hidden" name="CustomId.Elements[@i].Key.Format" value="@element.Format"/>

                                    <input type="text"
                                           name="CustomId.Elements[@i].Value"
                                           value="@(isFixed ? element.GetPreview() ?? "" : elementValue)"
                                           class="form-control custom-id-input @(isReadOnly ? "bg-light text-muted" : "")"
                                           placeholder="..."
                                           @(isReadOnly ? "readonly" : "")
                                           oninput="validateCustomId()"/>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Dynamic Fields Card -->
            <div class="card shadow-sm">
                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-input-cursor-text me-2"></i>Item Fields</h5>
                    <span class="badge bg-secondary" id="fieldCountBadge">@Model.FieldDefinitions.Count fields</span>
                </div>
                <div class="card-body">
                    @if (Model.FieldDefinitions.Any())
                    {
                        <div class="row g-3">
                            @foreach (var fieldDef in Model.FieldDefinitions.OrderBy(f => f.SortOrder))
                            {
                                var fieldValue = Model.Fields.ContainsKey(fieldDef.Id)
                                    ? Model.Fields[fieldDef.Id]
                                    : new FieldValueViewModel(fieldDef);

                                <div class="col-md-@(fieldDef.Type == FieldType.MultiLine ? "12" : "6") field-container"
                                     data-field-id="@fieldDef.Id"
                                     data-field-type="@fieldDef.Type">

                                    <label class="form-label fw-bold">
                                        @fieldDef.Title
                                        @if (fieldDef.IsRequired)
                                        {
                                            <span class="text-danger">*</span>
                                        }
                                    </label>

                                    @if (!string.IsNullOrEmpty(fieldDef.Description))
                                    {
                                        <div class="form-text mb-1">@fieldDef.Description</div>
                                    }

                                    @{
                                        string inputName = $"Fields[{fieldDef.Id}].Value";
                                        string inputId = $"field_{fieldDef.Id}";
                                        string currentValue = fieldValue.DisplayValue;
                                    }

                                    @switch (fieldDef.Type)
                                    {
                                        case FieldType.SingleLine:
                                            <input type="text"
                                                   name="@inputName"
                                                   id="@inputId"
                                                   value="@currentValue"
                                                   class="form-control"
                                                   placeholder="Enter @fieldDef.Title..."
                                                   @(fieldDef.IsRequired ? "required" : "")/>
                                            break;

                                        case FieldType.MultiLine:
                                            <textarea name="@inputName" 
                                                          id="@inputId"
                                                          class="form-control" 
                                                          rows="4"
                                                          placeholder="Enter @fieldDef.Title..."
                                                          @(fieldDef.IsRequired ? "required" : "")>@currentValue</textarea>
                                            break;

                                        case FieldType.Numeric:
                                            <div class="input-group">
                                                <span class="input-group-text">
                                                    <i class="bi bi-123"></i>
                                                </span>
                                                <input type="number"
                                                       name="@inputName"
                                                       id="@inputId"
                                                       value="@currentValue"
                                                       class="form-control"
                                                       step="any"
                                                       placeholder="0.00"
                                                       @(fieldDef.IsRequired ? "required" : "")/>
                                            </div>
                                            break;

                                        case FieldType.Boolean:
                                            <div class="form-check form-switch mt-2">
                                                <input type="hidden" name="@inputName" value="false"/>
                                                <input type="checkbox"
                                                       name="@inputName"
                                                       id="@inputId"
                                                       value="true"
                                                       class="form-check-input"
                                                       style="width: 3em; height: 1.5em;"
                                                       @(currentValue.ToLower() == "true" ? "checked" : "")/>
                                                <label class="form-check-label ms-2" for="@inputId">Yes / No</label>
                                            </div>
                                            break;

                                        case FieldType.Document:
                                            <div class="input-group">
                                                <span class="input-group-text">
                                                    <i class="bi bi-link-45deg"></i>
                                                </span>
                                                <input type="url"
                                                       name="@inputName"
                                                       id="@inputId"
                                                       class="form-control"
                                                       placeholder="https://..."
                                                       value="@currentValue"
                                                       @(fieldDef.IsRequired ? "required" : "") />
                                            </div>
                                            @if (!string.IsNullOrEmpty(currentValue))
                                            {
                                                <div class="mt-2">
                                                    <a href="@currentValue" target="_blank" class="btn btn-sm btn-outline-info">
                                                        <i class="bi bi-box-arrow-up-right me-1"></i>Open Document
                                                    </a>
                                                </div>
                                            }
                                            break;
                                    }

                                    <input type="hidden" name="Fields[@fieldDef.Id].FieldDefinitionId" value="@fieldDef.Id"/>
                                    <div class="invalid-feedback">Please provide a valid value for @fieldDef.Title.</div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info mb-0">
                            <i class="bi bi-info-circle me-2"></i>No custom fields defined for this item type.
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <!-- Metadata Card (only for existing items) -->
            @if (!isNewItem)
            {
                <div class="card shadow-sm mb-4 border-info">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0"><i class="bi bi-clock-history me-2"></i>Metadata</h5>
                    </div>
                    <div class="card-body">
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                <span class="text-muted">Item ID</span>
                                <code class="small">@Model.Id.ToString("D")</code>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                <span class="text-muted">Created</span>
                                <span>@Model.CreatedAt.Humanize()</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                <span class="text-muted">By</span>
                                <span class="badge bg-light text-dark">@Model.CreatedByUserName</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                <span class="text-muted">Last Updated</span>
                                <span>@Model.UpdatedAt.Humanize()</span>
                            </li>
                        </ul>
                    </div>
                </div>
            }

            <!-- Quick Actions -->
            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="bi bi-lightning-charge me-2"></i>Actions</h5>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        @if (!isNewItem)
                        {
                            <button type="button" class="btn btn-outline-danger" id="deleteBtn">
                                <i class="bi bi-trash me-2"></i>Delete Item
                            </button>
                        }
                    </div>
                </div>
            </div>

            <!-- Validation Summary -->
            <div id="validationSummary" class="alert alert-danger mt-4 d-none">
                <h6><i class="bi bi-exclamation-triangle me-2"></i>Please correct the following errors:</h6>
                <ul class="mb-0 small" id="validationList"></ul>
            </div>
        </div>
    </div>
</form>
</div>

<style>
    .field-container {
        transition: all 0.2s ease;
    }
        
    .field-container:hover {
        background-color: #f8f9fa;
    }

    .form-check-input:checked {
        background-color: #0d6efd;
        border-color: #0d6efd;
    }

    .card {
        border: none;
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075) !important;
    }

    .card-header {
        border-bottom: 1px solid rgba(0,0,0,.125);
    }

    code {
        background-color: #f8f9fa;
        padding: 0.2rem 0.4rem;
        border-radius: 0.25rem;
    }

    .form-control {
        transition: border-color 0.15s ease-in-out, box-shadow 0.15s ease-in-out;
    }
    
    .form-control[custom-id-input] {
        background-image: none !important;
        border-color: #dee2e6 !important;
    }

    .is-invalid {
        animation: shake 0.5s;
    }

    @@keyframes shake {
        0%, 100% { transform: translateX(0); }
        25% { transform: translateX(-5px); }
        75% { transform: translateX(5px); }
    }
</style>

<script>
    const form = document.getElementById('itemForm');
    const saveBtn = document.getElementById('saveBtn');
    const deleteBtn = document.getElementById('deleteBtn');
    const validationSummary = document.getElementById('validationSummary');
    const validationList = document.getElementById('validationList');
    const modelId = '@Model.Id';
    const inventoryId = '@Model.InventoryId';
    const isNewItem = @(isNewItem.ToString().ToLower());
    const submitUrl = '@Url.Action("SubmitChanges", "ItemEdit")';
    document.addEventListener('DOMContentLoaded', function() {
        saveBtn.addEventListener('click', async function() {
            clearValidationErrors();

            if (!form.checkValidity()) {
                form.reportValidity();
                showValidationErrors(['Please fill in all required fields correctly.']);
                return;
            }

            const formData = collectFormData();
            
            saveBtn.disabled = true;
            const originalText = saveBtn.innerHTML;
            saveBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Saving...';

            try {
                const response = await fetch(submitUrl, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: JSON.stringify(formData)
                });

                if (response.ok) {
                    showToast('Success', 'Item saved successfully!', 'success');
                    clearDraft();
                    setTimeout(() => {
                        window.location.href = '@inventoryUrl';
                    }, 1000);
                } else {
                    const errorText = await response.text();
                    showValidationErrors([errorText]);
                    console.error('Save failed:', errorText);
                }
            } catch (error) {
                showValidationErrors(['An error occurred while saving. Please check your connection and try again.']);
                console.error('Error:', error);
            } finally {
                saveBtn.disabled = false;
                saveBtn.innerHTML = originalText;
            }
        });

        if (deleteBtn) {
            deleteBtn.addEventListener('click', async function() {
                if (!confirm('Are you sure you want to delete this item? This action cannot be undone.')) {
                    return;
                }

                deleteBtn.disabled = true;
                const originalText = deleteBtn.innerHTML;
                deleteBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Deleting...';

                try {
                    const idArray = ['@Model.Id'];
                    const response2 = await postData('@Url.Action("DeleteItems", "InventoryEdit")', idArray);
                    
                    if (response2.ok) {
                        showToast('Deleted', 'Item has been deleted.', 'success');
                        setTimeout(() => {
                            window.location.href = '@inventoryUrl';
                        }, 1000);
                    } else {
                        showToast('Error', 'Failed to delete item.', 'danger');
                    }
                } catch (error) {
                    showToast('Error', 'An error occurred while deleting.', 'danger');
                    console.error('Delete error:', error);
                } finally {
                    deleteBtn.disabled = false;
                    deleteBtn.innerHTML = originalText;
                }
            });
        }

        function collectFormData() {
            const data = {
                Id: document.querySelector('input[name="Id"]').value || '@Guid.Empty',
                CustomId: getCustomId(),
                InventoryId: inventoryId,
                Fields: {},
                FieldDefinitions: []
            };

            const fieldContainers = document.querySelectorAll('.field-container');
            fieldContainers.forEach(container => {
                const fieldId = container.dataset.fieldId;
                const fieldType = container.dataset.fieldType;
                const inputElement = container.querySelector('input:not([type="hidden"]), textarea, select');
                
                if (inputElement) {
                    let value = inputElement.value;

                    if (fieldType === 'Boolean') {
                        value = inputElement.checked.toString();
                    }
                    
                    if (fieldType === 'Document' && inputElement.type === 'file') {
                        if (inputElement.files.length === 0) {
                            const existingLink = container.querySelector('a[href]');
                            value = existingLink ? existingLink.getAttribute('href') : '';
                        } else {
                            value = inputElement.files[0].name; 
                        }
                    }

                    data.Fields[fieldId] = {
                        Value: value
                    };
                }
            });

            @foreach (var def in Model.FieldDefinitions)
            {
                <text>
                data.FieldDefinitions.push({
                    Id: '@def.Id' 
                });
                </text>
            }

            return data;
        }

        function showToast(title, message, type) {
            const toastHtml = `
                <div class="toast align-items-center text-white bg-${type === 'success' ? 'success' : type === 'danger' ? 'danger' : 'primary'} border-0 position-fixed top-0 end-0 m-3" role="alert" style="z-index: 1055;">
                    <div class="d-flex">
                        <div class="toast-body">
                            <strong>${title}</strong><br>${message}
                        </div>
                        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                    </div>
                </div>
            `;
            
            const wrapper = document.createElement('div');
            wrapper.innerHTML = toastHtml;
            document.body.appendChild(wrapper);
            
            const toast = new bootstrap.Toast(wrapper.querySelector('.toast'));
            toast.show();
            
            setTimeout(() => wrapper.remove(), 5000);
        }

        document.querySelectorAll('input:not(.custom-id-input), textarea, select').forEach(input => {
            input.addEventListener('blur', function() {
                if (this.checkValidity()) {
                    this.classList.remove('is-invalid');
                    this.classList.add('is-valid');
                } else if (this.value !== '') {
                    this.classList.add('is-invalid');
                }
            });
            
            input.addEventListener('input', function() {
                if (this.classList.contains('is-invalid') && this.checkValidity()) {
                    this.classList.remove('is-invalid');
                }
            });
        });

        let autoSaveTimer;
        document.querySelectorAll('input, textarea').forEach(input => {
            input.addEventListener('input', function() {
                clearTimeout(autoSaveTimer);
                autoSaveTimer = setTimeout(() => {
                    localStorage.setItem('itemDraft_@Model.Id', JSON.stringify(collectFormData()));
                }, 2000);
            });
        });

        @if (isNewItem)
        {
            <text>
            const draft = localStorage.getItem('itemDraft_@Model.Id');
            if (draft) {
                try {
                    const draftData = JSON.parse(draft);
                    Object.keys(draftData.Fields).forEach(fieldId => {
                        const field = draftData.Fields[fieldId];
                        const input = document.getElementById(`field_${fieldId}`);
                        if (input) {
                            if (input.type === 'checkbox') {
                                input.checked = field.Value.toLowerCase() === 'true';
                            } else {
                                input.value = field.Value;
                            }
                        }
                    });
                } catch (e) {
                    console.error('Failed to restore draft:', e);
                }
            }
            </text>
        }

        function clearDraft() {
            localStorage.removeItem('itemDraft_@Model.Id');
        }
    });
    
    function showValidationErrors(errors) {
        validationList.innerHTML = errors.map(e => `<li>${e}</li>`).join('');
        validationSummary.classList.remove('d-none');
        validationSummary.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }    
    
    function clearValidationErrors() {
        validationSummary.classList.add('d-none');
        validationList.innerHTML = '';
        document.querySelectorAll('.is-invalid').forEach(el => el.classList.remove('is-invalid'));
    }
    
    function showIdPreview(id){
        const idLabel = document.getElementById('new-id-label');
        idLabel.innerHTML = 'New id: ' + id;
    }
    
    async function validateCustomId() {
        const payload = getCustomId()
 
        try {
            const response = await fetch(`/CustomId/ValidateId`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
        
            const result = await response.json();
            showIdPreview(result.preview);
            if (result.errors.length > 0)
                showValidationErrors(result.errors);
            else    
                clearValidationErrors();
        } catch (error) {
            console.error("Validation failed", error);
        }
    }    
    
    function getCustomId(){
        const container = document.getElementById('custom-id-editor');
        const values = [];
        const elements = [];
        const rows = container.querySelectorAll('.custom-id-row');
            rows.forEach(row => {
            const type = parseInt(row.querySelector('input[name*="Key.Type"]').value);
            const format = row.querySelector('input[name*="Key.Format"]').value;
            const value = row.querySelector('.custom-id-input').value;
            values.push(value);
            elements.push({Type: type, Format: format});
        });
        return {
            Values: values,
            Schema: {Elements: elements}
        };
    }
    
    validateCustomId();
</script>