@using ITask7.Models.Inventories
@model ITask7.ViewModels.Inventories.InventoryViewModel

@{
    ViewBag.Title = "title";
    Layout = "_Layout";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h2 class="fw-bold text-body">@Model.Name</h2>
</div>

<div class="card shadow-sm border-0">
    <div class="table-responsive rounded-3">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-body-secondary text-secondary small text-uppercase fw-bold">
            <tr>
                <th class="ps-4">Custom ID</th>
                @foreach (var field in Model.Fields.OrderBy(f => f.SortOrder).Where(f => f.DisplayInTable))
                {
                    <th>@field.Title</th>
                }
                <th class="pe-4">Created At</th>
            </tr>
            </thead>
            <tbody class="border-top-0">
            @if (!Model.Items.Any())
            {
                <tr>
                    <td colspan="@(Model.Fields.Count(f => f.DisplayInTable) + 2)" class="text-center py-5">
                        <div class="text-muted">
                            <i class="bi bi-inbox fs-1 d-block mb-2 opacity-50"></i>
                            <span>No items found in this inventory.</span>
                        </div>
                    </td>
                </tr>
            }
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td class="ps-4">
                        <a href="@Url.Action("Index", "ItemReadonly", new { itemId = item.Id })"
                           class="text-decoration-none fw-semibold link-primary">
                            <i class="bi bi-hash small"></i>@item.CustomIdString()
                        </a>
                    </td>

                    @foreach (var fieldDef in Model.Fields.OrderBy(f => f.SortOrder).Where(f => f.DisplayInTable))
                    {
                        <td>
                            @if (item.FieldValues.TryGetValue(fieldDef.Id, out var fieldValue))
                            {
                                if (fieldValue.Type == FieldType.Document && fieldValue.DisplayValue != "no data")
                                {
                                    <a href="@fieldValue.DisplayValue"
                                       class="btn btn-sm btn-outline-info py-0 px-2"
                                       onclick="event.stopPropagation();">
                                        <i class="bi bi-file-earmark-arrow-down small"></i> File
                                    </a>
                                }
                                else if (fieldValue.Type == FieldType.Boolean)
                                {
                                    bool isTrue = fieldValue.Value is true;
                                    <span class="text-body">
                                        @if (isTrue)
                                        {
                                            <i class="bi bi-check-circle-fill text-success"></i>
                                            <span>Yes</span>
                                        }
                                        else
                                        {
                                            <i class="bi bi-x-circle text-muted"></i>
                                            <span>No</span>
                                        }
                                    </span>
                                }
                                else
                                {
                                    <span class="text-body">@fieldValue.DisplayValue</span>
                                }
                            }
                            else
                            {
                                <span class="text-body-tertiary">@Html.Raw("&mdash;")</span>
                            }
                        </td>
                    }
                    <td class="pe-4 text-muted small">
                        @item.CreatedAtString
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>