@using ITask7.Localization
@using ITask7.Models.Users
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Mvc.TagHelpers
@inject UserManager<ApplicationUser> userManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - ITask7</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/ITask7.styles.css" asp-append-version="true"/>
    <link rel="stylesheet" href="https://unpkg.com/bootstrap-table@1.22.1/dist/bootstrap-table.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://unpkg.com/bootstrap-table@1.21.4/dist/bootstrap-table.min.css">
    <link rel="stylesheet" href="https://unpkg.com/bootstrap-table@1.21.4/dist/extensions/reorder-rows/bootstrap-table-reorder-rows.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
<header>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm bg-body border border-bottom box-shadow mb-3">
        <div class="container-fluid">
            <!-- Brand -->
            <a class="navbar-brand" asp-area="" asp-controller="Main" asp-action="Index">ITask7</a>

            <!-- Toggler -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                    aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Collapsible Content -->
            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between" id="mainNavbar">
                <!-- Left Navigation -->
                <ul class="navbar-nav flex-grow-1">
                    @{
                        ApplicationUser? user = await userManager.GetUserAsync(User);
                    }
                    @if (user?.IsBlocked ?? false)
                    {
                        <div class="alert alert-danger d-flex align-items-center mb-0 ms-3 px-4 py-2 border-0 rounded shadow" role="alert">
                            <span class="fs-4 me-2">⚠️</span>
                            YOUR ACCOUNT HAS BEEN BLOCKED
                        </div>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">My inventories</a>
                        </li>
                        @if (user?.IsAdmin ?? false)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="AdminPanel" asp-action="Index">Admin panel</a>
                            </li>
                        }
                    }
                </ul>

                <!-- Right Section: Login + Language -->
                <div class="d-flex align-items-center gap-3">
                    <partial name="_LoginPartial"/>

                    <!-- Language Dropdown -->
                    <div class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle d-flex align-items-center gap-2 border rounded px-3 py-1" href="#" role="button"
                           data-bs-toggle="dropdown" aria-expanded="false" style="min-width: 140px;">
                            <i class="bi bi-globe"></i>
                            <span>@Languages.GetLanguageName(System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName)</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            @foreach (string lang in Languages.All)
                            {
                                <li>
                                    <a class="dropdown-item" asp-controller="Localization" asp-action="Index"
                                       asp-route-culture="@lang">
                                        @Languages.GetLanguageName(lang)
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>
                    <button class="btn btn-outline-secondary border-0" id="themeToggle">
                        <i class="bi bi-sun-fill" id="themeIcon"></i>
                    </button>
                </div>
            </div>
        </div>
    </nav>
</header>
<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<footer class="border-top footer text-muted">
    <div class="container">
        &copy; 2026 - ITask7
    </div>
</footer>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script src="https://unpkg.com/bootstrap-table@1.22.1/dist/bootstrap-table.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/TableDnD/0.9.1/jquery.tablednd.js" integrity="sha256-d3rtug+Hg1GZPB7Y/yTcRixO/wlI78+2m08tosoRn7A=" crossorigin="anonymous"></script>
<script src="https://unpkg.com/bootstrap-table@1.21.4/dist/extensions/reorder-rows/bootstrap-table-reorder-rows.min.js"></script>

<script>
    const themeToggle = document.getElementById('themeToggle');
    const themeIcon = document.getElementById('themeIcon');
    const htmlElement = document.documentElement;

    // Function to update the icon
    const updateIcon = (theme) => {
        themeIcon.className = theme === 'dark' ? 'bi bi-moon-stars-fill' : 'bi bi-sun-fill';
    };

    themeToggle.addEventListener('click', () => {
        const currentTheme = htmlElement.getAttribute('data-bs-theme');
        const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
        
        htmlElement.setAttribute('data-bs-theme', newTheme);
        localStorage.setItem('theme', newTheme);
        updateIcon(newTheme);
    });

    // Check for saved preference on load
    const savedTheme = localStorage.getItem('theme') || 'dark';
    htmlElement.setAttribute('data-bs-theme', savedTheme);
    updateIcon(savedTheme);


    async function postData(url, data) {
        try {
            const options = {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            };
            if (data !== null) options.body = JSON.stringify(data);
            
            const response = await fetch(url, options);
            if (!response.ok) throw new Error(response.statusText);
            return true;
        } catch (error) {
            console.error('Error:', error);
            alert('Failed to perform action');
            return false;
        }
    }
    
    
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>