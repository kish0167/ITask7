@model ITask7.ViewModels.UI.BulkActionToolbarViewModel

@{
    var toolbarId = $"bulk-toolbar-{Guid.NewGuid():N}";
}

<div class="btn-group mt-3 gap-2" id="@toolbarId" data-selection-mode="multiple">
    @foreach (var action in Model.Actions)
    {
        <button class="btn @action.ButtonClass" 
                title="@action.Title"
                data-action="@action.Name"
                data-endpoint="@action.Endpoint">
            <i class="bi @action.Icon"></i>
            <span class="d-none d-sm-inline ms-1">@action.Title</span>
        </button>
    }
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
(function() {
    const toolbarId = '@toolbarId';
    const toolbar = document.getElementById(toolbarId);
    if (!toolbar) return;
    
    const context = toolbar.closest('[data-bulk-context]') || document.body;
    
    // Generate unique function names for this instance
    const ns = `bulkToolbar_${toolbarId.replace(/-/g, '_')}`;
    
    // Helper to get checkboxes scoped to this context
    function getCheckboxes() {
        return context.querySelectorAll('.selectable-item');
    }
    
    // Helper to get select-all checkbox scoped to this context
    function getSelectAllCheckbox() {
        return context.querySelector('.select-all');
    }    
    
    function getSelectedIds() {
        return Array.from(context.querySelectorAll('.selectable-item:checked')).map(cb => cb.value);
    }
    
    async function bulkAction(actionName) {
        const selectedIds = getSelectedIds();
        
        if (selectedIds.length === 0) {
            alert('Please select at least one item');
            return;
        }
        
        const btn = context.querySelector(`[data-action="${actionName}"]`);
        const endpoint = btn.dataset.endpoint;
        
        if (!confirm(`${actionName} ${selectedIds.length} items?`)) return;
        
        const contextId = context.dataset?.contextId;
        const success = await postData(endpoint + (contextId ? `?contextId=${contextId}`: ''), selectedIds);
        if (success) {
            context.dispatchEvent(new CustomEvent('bulkActionSuccess', {
                detail: { action: actionName, ids: selectedIds, toolbarId: '@toolbarId', context: context}
            }));
        }
    };
    
    // Toggle all items in this context
    function toggleSelectAll() {
        const selectAll = getSelectAllCheckbox();
        if (!selectAll) return;
        
        const checkboxes = getCheckboxes();
        checkboxes.forEach(cb => {
            cb.checked = selectAll.checked;
            toggleItemHighlight(cb);
        });
    }
    
    // Toggle single item (can be called from row click)
    function toggleItem(item) {
        const checkbox = item.querySelector('.selectable-item');
        if (!checkbox) return;
        
        checkbox.checked = !checkbox.checked;
        toggleItemHighlight(checkbox);
        
        // Update select-all checkbox state
        updateSelectAllState();
    }
    
    // Highlight row based on checkbox state
    function toggleItemHighlight(checkbox) {
        const row = checkbox.closest('tr');
        if (row) {
            row.classList.toggle('table-active', checkbox.checked);
        }
    }
    
    // Update select-all checkbox based on individual selections
    function updateSelectAllState() {
        const selectAll = getSelectAllCheckbox();
        if (!selectAll) return;
        
        const checkboxes = Array.from(getCheckboxes());
        const allChecked = checkboxes.length > 0 && checkboxes.every(cb => cb.checked);
        const someChecked = checkboxes.some(cb => cb.checked);
        
        selectAll.checked = allChecked;
        selectAll.indeterminate = someChecked && !allChecked;
    }
    
    // Attach event listeners to toolbar buttons
    toolbar.querySelectorAll('button[data-action]').forEach(btn => {
        btn.addEventListener('click', (e) => {
            e.preventDefault();
            bulkAction(btn.dataset.action);
        });
    });
    
    // Listen for select-all changes within this context
    const selectAllCheckbox = getSelectAllCheckbox();
    if (selectAllCheckbox) {
        selectAllCheckbox.addEventListener('change', toggleSelectAll);
    }
    
    // Listen for individual checkbox changes to update highlighting and select-all state
    getCheckboxes().forEach(cb => {
        cb.addEventListener('change', () => {
            toggleItemHighlight(cb);
            updateSelectAllState();
        });
    });
    
    toolbar.bulkToolbarApi = {
        getSelectedIds,
        bulkAction,
        toggleItem,
        refresh: updateSelectAllState
    };
    
    // Store reference to avoid memory leaks
    toolbar.dataset.toolbarInstance = toolbarId;    
})();});
</script>
