@model ITask7.ViewModels.UI.BulkActionToolbarViewModel

@{
    var toolbarId = $"bulk-toolbar-{Guid.NewGuid():N}";
}

<div class="btn-group mt-3 gap-2" id="@toolbarId" data-selection-mode="multiple">
    @foreach (var action in Model.Actions)
    {
        <button class="btn @action.ButtonClass" 
                title="@action.Title"
                data-action="@action.Name"
                data-endpoint="@action.Endpoint">
            <i class="bi @action.Icon"></i>
            <span class="d-none d-sm-inline ms-1">@action.Title</span>
        </button>
    }
</div>

<script>
(function() {
    const toolbar = document.getElementById('@toolbarId');
    if (!toolbar) return;
    
    const context = toolbar.closest('[data-bulk-context]') || document;
    
    window.getSelectedIds = function() {
        return Array.from(context.querySelectorAll('.selectable-item:checked')).map(cb => cb.value);
    };
    
    window.bulkAction = async function(actionName) {
        const selectedIds = getSelectedIds();
        
        if (selectedIds.length === 0) {
            alert('Please select at least one item');
            return;
        }
        
        const btn = context.querySelector(`[data-action="${actionName}"]`);
        const endpoint = btn.dataset.endpoint;
        
        if (!confirm(`${actionName} ${selectedIds.length} items?`)) return;
        
        const contextId = context.dataset?.contextId;
        const success = await postData(endpoint + (contextId ? `?contextId=${contextId}`: ''), selectedIds);
        if (success) {
            context.dispatchEvent(new CustomEvent('bulkActionSuccess', {
                detail: { action: actionName, ids: selectedIds, toolbarId: '@toolbarId'}
            }));
        }
    };
    
    toolbar.querySelectorAll('button[data-action]').forEach(btn => {
        btn.addEventListener('click', () => bulkAction(btn.dataset.action));
    });
})();

function toggleSelectAll() {
    const selectAll = document.getElementById('selectAll');
    const checkboxes = document.querySelectorAll('.selectable-item');
    checkboxes.forEach(cb => {cb.checked = selectAll.checked; toggleItemHighlight(cb)});
}
    
function toggleItem(item) {
    const checkbox = item.querySelector('.selectable-item');
    checkbox.checked = !checkbox.checked;
    toggleItemHighlight(checkbox);
}

function toggleItemHighlight(checkbox) {
    checkbox.closest('tr').classList.toggle('table-active', checkbox.checked);
}
</script>
