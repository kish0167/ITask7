@model ITask7.ViewModels.HomePageViewModel

@{
    ViewData["Title"] = "Home Page";
}

<div class="container py-4">
    <!-- Header -->
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold text-primary">@Localizer["welcome"]</h1>
        <p class="text-muted">Manage your inventories and collaborate with your team</p>
    </div>

    <!-- Owned Inventories Section -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">
                <i class="bi bi-box-seam me-2"></i>My Inventories
            </h5>
            <div class="d-flex align-items-center gap-2">
                <span class="badge bg-light text-primary">@Model.OwnedInventories.Count</span>
                <button type="button" class="btn btn-light btn-sm" data-bs-toggle="modal" data-bs-target="#createInventoryModal">
                    <i class="bi bi-plus-lg"></i> New
                </button>
            </div>
        </div>
        <div class="card-body p-0">
            @if (Model.OwnedInventories.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                        <tr>
                            <th>Name</th>
                            <th>Description</th>
                            <th>Visibility</th>
                            <th>Items</th>
                            <th>Shared With</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var inventory in Model.OwnedInventories)
                        {
                            <tr class="cursor-pointer" onclick="location.href='@Url.Action("Index", "InventoryEdit", new { inventoryId = inventory.Id })'" style="cursor: pointer;">
                                <td class="fw-semibold text-primary">@inventory.Name</td>
                                <td class="text-truncate" style="max-width: 250px;" title="@inventory.Description">
                                    @(string.IsNullOrEmpty(inventory.Description) ? "-" : inventory.Description)
                                </td>
                                <td>
                                    @if (inventory.IsPublic)
                                    {
                                        <span class="badge bg-success">Public</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Private</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge bg-warning text-dark">@inventory.Items.Count</span>
                                </td>
                                <td>
                                    @if (inventory.WriteAccessUsers.Any())
                                    {
                                        <span class="badge bg-dark" title="@string.Join(", ", inventory.WriteAccessUsers.Select(u => u.Email))">
                                            @inventory.WriteAccessUsers.Count users
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-inbox display-4 d-block mb-3"></i>
                    <p>You don't own any inventories yet.</p>
                    <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#createInventoryModal">
                        <i class="bi bi-plus-lg me-1"></i>Create your first inventory
                    </button>
                </div>
            }
        </div>
    </div>

    <!-- Available Inventories Section -->
    <div class="card shadow-sm">
        <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">
                <i class="bi bi-people me-2"></i>Shared With Me
            </h5>
            <span class="badge bg-light text-success">@Model.AvailableInventories.Count</span>
        </div>
        <div class="card-body p-0">
            @if (Model.AvailableInventories.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                        <tr>
                            <th>Name</th>
                            <th>Description</th>
                            <th>Owner</th>
                            <th>Items</th>
                            <th>Your Access</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var inventory in Model.AvailableInventories)
                        {
                            <tr class="cursor-pointer" onclick="location.href='@Url.Action("Index", "InventoryEdit", new { inventoryId = inventory.Id })'" style="cursor: pointer;">
                                <td class="fw-semibold text-success">@inventory.Name</td>
                                <td class="text-truncate" style="max-width: 250px;" title="@inventory.Description">
                                    @(string.IsNullOrEmpty(inventory.Description) ? "-" : inventory.Description)
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark border">
                                        <i class="bi bi-person-circle me-1"></i>@inventory.CreatedBy
                                    </span>
                                </td>
                                <td>
                                    <span class="badge bg-warning text-dark">@inventory.Items.Count</span>
                                </td>
                                <td>
                                    <span class="badge bg-success">
                                        <i class="bi bi-pencil-square me-1"></i>Write
                                    </span>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-lock display-4 d-block mb-3"></i>
                    <p>No inventories have been shared with you.</p>
                </div>
            }
        </div>
    </div>
    
    <!-- Create Inventory Modal -->
    <div class="modal fade" id="createInventoryModal" tabindex="-1" aria-labelledby="createInventoryModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title" id="createInventoryModalLabel">
                        <i class="bi bi-plus-circle me-2"></i>Create New Inventory
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="createInventoryForm">
                        <div class="mb-3">
                            <label for="inventoryTitle" class="form-label fw-semibold">Title <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="inventoryTitle" name="Name" required maxlength="100" placeholder="Enter inventory name">
                        </div>
                        <div class="mb-3">
                            <label for="inventoryDescription" class="form-label fw-semibold">Description</label>
                            <textarea class="form-control" id="inventoryDescription" name="Description" rows="3" maxlength="500" placeholder="Enter description (optional)"></textarea>
                        </div>
                        <div class="mb-3 form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="inventoryIsPublic" name="IsPublic" value="true">
                            <label class="form-check-label fw-semibold" for="inventoryIsPublic">Make Public</label>
                            <div class="form-text text-muted">Public inventories can be viewed by anyone with the link.</div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" id="submitInventoryBtn">
                        <i class="bi bi-check-lg me-1"></i>Create Inventory
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .cursor-pointer:hover {
        background-color: rgba(0,0,0,0.02) !important;
        transition: background-color 0.2s ease;
    }
    
    .card {
        border: none;
        border-radius: 0.5rem;
    }
    
    .card-header {
        border-radius: 0.5rem 0.5rem 0 0 !important;
        padding: 1rem 1.25rem;
    }
    
    .table th {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.5px;
        color: #6c757d;
    }
</style>

<script>
    document.getElementById('submitInventoryBtn').addEventListener('click', async function() {
        const form = document.getElementById('createInventoryForm');
        const titleInput = document.getElementById('inventoryTitle');
        
        if (!titleInput.value.trim()) {
            titleInput.classList.add('is-invalid');
            return;
        }
        titleInput.classList.remove('is-invalid');
        
        const model = {
            Name: titleInput.value.trim(),
            Description: document.getElementById('inventoryDescription').value.trim(),
            IsPublic: document.getElementById('inventoryIsPublic').checked
        };
        
        const submitBtn = document.getElementById('submitInventoryBtn');
        const originalText = submitBtn.innerHTML;
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Creating...';
        
        try {
            const response = await fetch('@Url.Action("NewInventory", "InventoryCreate")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                },
                body: JSON.stringify(model)
            });
            
            if (response.ok) {
                const inventoryId = await response.json();
                // Redirect to the new inventory
                window.location.href = '@Url.Action("Index", "InventoryEdit")?inventoryId=' + inventoryId;
            } else {
                alert('Failed to create inventory. Please try again.');
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalText;
            }
        } catch (error) {
            console.error('Error:', error);
            alert('An error occurred. Please try again.');
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalText;
        }
    });
    
    document.getElementById('inventoryTitle').addEventListener('input', function() {
        this.classList.remove('is-invalid');
    });
    
    document.getElementById('createInventoryModal').addEventListener('hidden.bs.modal', function() {
        document.getElementById('createInventoryForm').reset();
        document.getElementById('inventoryTitle').classList.remove('is-invalid');
        document.getElementById('submitInventoryBtn').disabled = false;
        document.getElementById('submitInventoryBtn').innerHTML = '<i class="bi bi-check-lg me-1"></i>Create Inventory';
    });
</script>