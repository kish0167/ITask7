@using ITask7.ViewModels.UI
@model System.Collections.Generic.List<ITask7.ViewModels.UserViewModel>

@{
    ViewBag.Title = "Admin panel";
    Layout = "_Layout";
    var toolbarModel = new BulkActionToolbarViewModel
    {
        Actions = new()
        {
            new() { Name = "delete", Title = "Delete", Icon = "bi-trash-fill", 
                    ButtonClass = "btn-danger", Endpoint = "/AdminPanel/BulkDelete" },
            new() { Name = "block", Title = "Block", Icon = "bi-lock-fill", 
                    ButtonClass = "btn-warning", Endpoint = "/AdminPanel/BulkBlock" },
            new() { Name = "unblock", Title = "Unblock", Icon = "bi-unlock-fill", 
                    ButtonClass = "btn-info", Endpoint = "/AdminPanel/BulkUnblock" }
        }
    };
}

<h1>Admin panel</h1>
<partial name="Components/BulkActionToolbar/Default" model="toolbarModel" />
<table class="table table-hover mb-0 align-middle">
    <thead>
    <tr>
        <th>
            <input class="form-check-input"
                   type="checkbox" 
                   id="selectAll"
                   onclick="toggleSelectAll()">
        </th>
        <th>Email</th>
        <th>Status</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var user in Model)
    {
        <tr onclick="toggleItem(this)" style="cursor: pointer;" data-user-id="@user.Id">
            <td onclick="event.stopPropagation()">
                <input class="form-check-input selectable-item"
                       type="checkbox"
                       value="@user.Id"
                       data-user-id="@user.Id"
                       onchange="toggleItemHighlight(this)">
            </td>
            <td>@user.Email</td>
            <td class="user-status">@user.Status</td>
        </tr>
    }
    </tbody>
</table>

<script>

    // ==================== TOOLBAR REQS ====================
    
    document.addEventListener('bulkActionSuccess', function(e) {
        const { action, ids } = e.detail; 
        handleActionSuccess(action, ids);
    }); 

    // ==================== UI UPDATES ====================
    
    function handleActionSuccess(action, userIds) {
        alert('Success!');
            
        if (action === 'delete'){
            removeRows(userIds);
        } else if (action === 'block'){
            updateStatuses(userIds, 'Blocked');
        } else if (action === 'unblock'){
            updateStatuses(userIds, 'Active');
        }
    }
    
    function removeRows(userIds) {
        userIds.forEach(id => {
            const row = document.querySelector(`tr[data-user-id="${id}"]`);
            if (row) row.remove();
        });
    }
    
    function updateStatuses(userIds, newStatus) {
        userIds.forEach(id => {
            const statusCell = getStatusCell(id);
            if (statusCell) {
                statusCell.textContent = newStatus;
                statusCell.setAttribute('data-user-status', newStatus);
            }
        });
    }
        
    function getStatusCell(userId) {
        return document.querySelector(`tr[data-user-id="${userId}"] .user-status`);
    }        
        
</script>