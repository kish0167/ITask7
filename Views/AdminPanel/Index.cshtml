@using ITask7.ViewModels.UI
@model System.Collections.Generic.List<ITask7.ViewModels.UserViewModel>

@{
    ViewBag.Title = "Admin panel";
    Layout = "_Layout";
    var toolbarModel = new BulkActionToolbarViewModel
    {
        Actions = new()
        {
            new() { Name = "delete", Title = "Delete", Icon = "bi-trash-fill", 
                    ButtonClass = "btn-outline-danger", Endpoint = "/AdminPanel/BulkDelete", IsSingle = false},
            new() { Name = "block", Title = "Block", Icon = "bi-lock-fill", 
                    ButtonClass = "btn-outline-warning", Endpoint = "/AdminPanel/BulkBlock", IsSingle = false },
            new() { Name = "unblock", Title = "Unblock", Icon = "bi-unlock-fill", 
                    ButtonClass = "btn-outline-info", Endpoint = "/AdminPanel/BulkUnblock", IsSingle = false },
            new() { Name = "admin", Title = "Make admin", Icon = "bi-person-gear", 
                ButtonClass = "btn-outline-success", Endpoint = "/AdminPanel/BulkAdmin", IsSingle = false },
            new() { Name = "deAdmin", Title = "De-admin", Icon = "bi-person-x", 
                ButtonClass = "btn-outline-secondary", Endpoint = "/AdminPanel/BulkDeAdmin", IsSingle = false }
        }
    };
}

<h1>Admin panel</h1>
<div data-bulk-context="adminPanel" data-context-id="0">
<partial name="Components/BulkActionToolbar/Default" model="toolbarModel" />
<table class="table table-hover mb-0 align-middle">
    <thead>
    <tr>
        <th>
            <input class="form-check-input select-all"
                   type="checkbox">
        </th>
        <th>Email</th>
        <th>Status</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var user in Model)
    {
        <tr onclick="toggleItem(this)" style="cursor: pointer;" data-user-id="@user.Id">
            <td onclick="event.stopPropagation()">
                <input class="form-check-input selectable-item"
                       type="checkbox"
                       value="@user.Id">
            </td>
            <td>@user.Email</td>
            <td class="user-status" data-user-id="@user.Id">
                <span class="status-text">@user.Status</span>
            </td>
        </tr>
    }
    </tbody>
</table>
</div>

<script>
    // ==================== TOOLBAR REQS ====================
    
    const context = document.querySelector('[data-bulk-context]') || document
    context.addEventListener('bulkActionSuccess', function(e) {
        const { action, ids } = e.detail; 
        handleActionSuccess(action, ids);
    }); 

    // ==================== UI UPDATES ====================
    
    const icons = { Admin: "value1", Blocked: "value2", Active: "value3"};
    
    function handleActionSuccess(action, userIds) {     
        if (action === 'delete'){
            location.reload();
        } else if (action === 'block'){
            location.reload();
        } else if (action === 'unblock'){
            updateStatuses(userIds, '✅ Active');
        } else if (action === 'admin'){
            updateStatuses(userIds, '🛡️ Admin');
        } else if (action === 'deAdmin'){
            location.reload();
        }
    }
    
    function removeRows(userIds) {
        userIds.forEach(id => {
            const row = document.querySelector(`tr[data-user-id="${id}"]`);
            if (row) row.remove();
        });
    }
    
    function updateStatuses(userIds, newStatus) {
        userIds.forEach(id => {
            const statusCell = getStatusCell(id);
            if (statusCell) {
                const textItem = statusCell.querySelector('.status-text');
                if (textItem) textItem.textContent = newStatus;
                    statusCell.setAttribute('data-user-status', newStatus);
            }
        });
    }
        
    function getStatusCell(userId) {
        return document.querySelector(`tr[data-user-id="${userId}"] .user-status`);
    }       
        
</script>