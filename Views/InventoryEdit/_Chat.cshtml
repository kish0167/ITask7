@using Markdig
@using Microsoft.AspNetCore.Mvc.TagHelpers
@model ITask7.ViewModels.Pages.InventoryEditPageViewModel
<div class="card shadow-sm" id="chat-container" data-inventory-id="@Model.Inventory.Id">
    <div class="card-header bg-body-tertiary text-body d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            <i class="bi bi-chat-dots me-2"></i>Inventory Discussion
        </h5>
    </div>
    
    <div class="card-body p-0">
        <!-- Messages Container -->
        <div id="chat-messages" class="chat-messages p-3" style="height: 400px; overflow-y: auto;">
            @if (Model.Inventory.ChatViewModel.Messages.Any())
            {
                @foreach (var message in Model.Inventory.ChatViewModel.Messages.OrderBy(m => m.SentAt))
                {
                    <div class="message mb-3" data-sender="@message.SenderName">
                        <div class="d-flex @(message.SenderName == User.Identity?.Name ? "justify-content-end" : "justify-content-start")">
                            <div class="message-bubble p-2 px-3 rounded-3 @(message.SenderName == User.Identity?.Name ? "message-mine" : "message-other")" style="max-width: 75%;">
                                <div class="message-header small mb-1">
                                    <strong>@message.SenderName</strong>
                                    <span class="ms-2 text-secondary">@message.SentAt.ToString("HH:mm")</span>
                                </div>
                                <div class="message-text markdown-content">@Html.Raw(Markdown.ToHtml(message.Text, new MarkdownPipelineBuilder()
                                                                               .UseSoftlineBreakAsHardlineBreak()
                                                                               .UsePipeTables()
                                                                               .UseGridTables()
                                                                               .Build()))</div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center text-muted py-5" id="no-messages">
                    <i class="bi bi-inbox display-4 d-block mb-2"></i>
                    No messages yet. Start the conversation!
                </div>
            }
        </div>
    </div>
    
    <div class="card-footer">
        <form id="chat-form" class="d-flex gap-2">
            <textarea id="message-input" class="form-control" rows="1" placeholder="Type a message..." autocomplete="off" maxlength="2000" style="resize: none; min-height: 38px; max-height: 120px;"></textarea>
            <button type="submit" class="btn btn-primary" id="send-btn">
                <i class="bi bi-send"></i>
            </button>
        </form>
    </div>
</div>

<style>
    .chat-messages {
        background-color: var(--bs-body-bg);
    }
    
    .message-bubble {
        word-wrap: break-word;
        background-color: var(--bs-secondary-bg);
        border: 1px solid var(--bs-border-color);
        color: var(--bs-body-color);
    }
    
    .message-mine {
        background-color: var(--bs-primary-bg-subtle);
        border: 2px solid var(--bs-primary);
        color: var(--bs-body-color);
    }
    
    .message-mine .message-header strong {
        color: var(--bs-primary);
    }
    
    .message-header strong {
        color: var(--bs-body-color);
    }
    
    .message {
        animation: fadeIn 0.3s ease-in;
    }
    
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    
    #chat-messages::-webkit-scrollbar {
        width: 6px;
    }
    
    #chat-messages::-webkit-scrollbar-thumb {
        background-color: var(--bs-secondary);
        border-radius: 3px;
    }
    
    #chat-messages::-webkit-scrollbar-track {
        background-color: var(--bs-secondary-bg);
    }

    /* Markdown Content Styling with CSS Variables */
    .markdown-content p { margin-bottom: 0.5rem; }
    .markdown-content p:last-child { margin-bottom: 0; }
    .markdown-content ul, .markdown-content ol { 
        padding-left: 1.25rem; 
        margin-bottom: 0.5rem; 
    }
    
    .markdown-content code { 
        background: var(--bs-secondary-bg); 
        color: var(--bs-code-color); 
        padding: 0.125rem 0.25rem; 
        border-radius: 3px; 
        font-size: 0.875em; 
    }
    
    .message-mine .markdown-content code {
        background: rgba(var(--bs-primary-rgb), 0.15);
        color: var(--bs-primary);
    }
    
    .markdown-content pre { 
        background: var(--bs-tertiary-bg); 
        padding: 0.75rem; 
        border-radius: 4px; 
        overflow-x: auto; 
        margin-bottom: 0.5rem; 
    }
    
    .markdown-content pre code { 
        background: none; 
        padding: 0; 
        color: var(--bs-body-color);
    }
    
    .markdown-content blockquote { 
        border-left: 3px solid var(--bs-border-color); 
        padding-left: 0.75rem; 
        margin-left: 0; 
        color: var(--bs-secondary-color); 
    }
    
    .markdown-content h1, .markdown-content h2, .markdown-content h3 { 
        font-size: 1.1em; 
        margin-bottom: 0.5rem; 
        font-weight: bold; 
        color: var(--bs-body-color);
    }
    
    .markdown-content table { 
        width: 100%; 
        border-collapse: collapse; 
        margin-bottom: 0.5rem; 
    }
    
    .markdown-content th, .markdown-content td { 
        border: 1px solid var(--bs-border-color); 
        padding: 0.375rem; 
    }
    
    .markdown-content th { 
        background: var(--bs-secondary-bg); 
    }
    
    .markdown-content td {
        background: var(--bs-body-bg);
    }
    
    /* Ensure footer matches card theme */
    .card-footer {
        background-color: var(--bs-card-cap-bg);
        border-top: 1px solid var(--bs-card-border-color);
    }
</style>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.js"></script>
<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/dompurify@3.0.5/dist/purify.min.js"></script>

<script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/ChatHub")
            .withAutomaticReconnect()
            .build();
            
        connection.start().then(() => {
            return connection.invoke("JoinInventoryGroup", '@Model.Inventory.ChatViewModel.InventoryId.ToString()');
        });
        
        document.getElementById('chat-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            const input = document.getElementById('message-input');
            const text = input.value;
            if (!text.trim()) return;
            const inventoryId = document.getElementById('chat-container').dataset.inventoryId;
            
            if (!text) return;

            await fetch(`/Chat/SendMessage?inventoryId=${inventoryId}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(text)
            });
            
            input.value = '';
        });
        
        connection.on("ReceiveMessage", (data) => {
            const isMe = data.senderName === '@Model.Inventory.ChatViewModel.CurrentUserName';
            const html = `
                    <div class="message mb-3" data-sender="${data.senderName}">
                        <div class="d-flex ${isMe ? "justify-content-end" : "justify-content-start"}">
                            <div class="message-bubble p-2 px-3 rounded-3 ${isMe ? "message-mine" : "message-other"}">
                                <div class="message-header small mb-1">
                                    <strong>${data.senderName}</strong>
                                    <span class="ms-2 text-secondary">${new Date(data.sentAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}</span>
                                </div>
                                <div class="message-text markdown-content"></div>
                            </div>
                        </div>
                    </div>
                `;
            
            document.getElementById('chat-messages').insertAdjacentHTML('beforeend', html);
            scrollToBottom();
            
            const messageDiv = document.getElementById('chat-messages').lastElementChild;
            const contentDiv = messageDiv.querySelector('.markdown-content');
            contentDiv.innerHTML = DOMPurify.sanitize(marked.parse(data.text));
            
            document.getElementById('no-messages')?.remove();
        });
        
        function scrollToBottom() {
            const container = document.getElementById('chat-messages');
            container.scrollTop = container.scrollHeight;
        }
        
        const textarea = document.getElementById('message-input');
        
        textarea.addEventListener('input', function() {
            this.style.height = 'auto';
            this.style.height = Math.min(this.scrollHeight, 120) + 'px';
        });
        
        textarea.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                document.getElementById('chat-form').dispatchEvent(new Event('submit'));
            }
        });
</script>
