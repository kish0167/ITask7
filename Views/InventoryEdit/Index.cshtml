@model ITask7.ViewModels.Pages.InventoryEditPageViewModel

@{
    ViewBag.Title = Model.Inventory.Name;
    Layout = "_Layout";
}

<div class="container mt-4">
    <!-- Header Section -->
    <div class="d-flex align-items-center mb-4">
        <h1 class="mb-0 me-3">@Model.Inventory.Name</h1>
        <span class="badge bg-success bg-opacity-10 text-success px-3 py-2 rounded-pill">
            <i class="bi bi-check-circle-fill me-1"></i>Nothing is saved, but it's ok
        </span>
    </div>

    <!-- Tabs Navigation -->
    <ul class="nav nav-tabs border-bottom" id="inventoryTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link @(Model.TabOpened == "items" ? "active" : "")" onclick="setTabQueryParameter('items')" id="items-tab" data-bs-toggle="tab" data-bs-target="#items" type="button" role="tab">
                Items
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link @(Model.TabOpened == "chat" ? "active" : "")" onclick="setTabQueryParameter('chat')" id="chat-tab" data-bs-toggle="tab" data-bs-target="#chat" type="button" role="tab">
                Chat
            </button>
        </li>
        @if (Model.CreatorAccess)
        {
            <li class="nav-item" role="presentation">
                <button class="nav-link @(Model.TabOpened == "settings" ? "active" : "")" onclick="setTabQueryParameter('settings')" id="settings-tab" data-bs-toggle="tab" data-bs-target="#settings" type="button" role="tab">
                    Settings
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(Model.TabOpened == "customid" ? "active" : "")" onclick="setTabQueryParameter('customid')" id="customid-tab" data-bs-toggle="tab" data-bs-target="#customid" type="button" role="tab">
                    Custom ID
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(Model.TabOpened == "fields" ? "active" : "")" onclick="setTabQueryParameter('fields')" id="fields-tab" data-bs-toggle="tab" data-bs-target="#fields" type="button" role="tab">
                    Fields
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(Model.TabOpened == "access" ? "active" : "")" onclick="setTabQueryParameter('access')" id="access-tab" data-bs-toggle="tab" data-bs-target="#access" type="button" role="tab">
                    Access
                </button>
            </li>
        }
    </ul>

    <!-- Tab Content -->
    <div class="tab-content py-4" id="inventoryTabsContent">
        <!-- Items -->
        <div class="tab-pane @(Model.TabOpened == "items" ? "show active" : "")" id="items" role="tabpanel">
            <partial name="_Items" model="Model.Inventory"/>
        </div>
        <!-- Chat -->
        <div class="tab-pane fade @(Model.TabOpened == "chat" ? "show active" : "")" id="chat" role="tabpanel">
            <partial name="_Chat" model="Model.Inventory"/>
        </div>
        @if (Model.CreatorAccess)
        {
            <!-- Settings -->
            <div class="tab-pane fade @(Model.TabOpened == "settings" ? "show active" : "")" id="settings" role="tabpanel">
                <partial name="_Settings" model="Model.Inventory"/>
            </div>
            <!-- Custom Id's -->
            <div class="tab-pane fade @(Model.TabOpened == "customid" ? "show active" : "")" id="customid" role="tabpanel">
                <partial name="_CustomId" model="Model.Inventory"/>
            </div>
            <!-- Fields -->
            <div class="tab-pane fade @(Model.TabOpened == "fields" ? "show active" : "")" id="fields" role="tabpanel">
                <partial name="_Fields" model="Model.Inventory"/>
            </div>
            <!-- Access -->
            <div class="tab-pane fade @(Model.TabOpened == "access" ? "show active" : "")" id="access" role="tabpanel">
                <partial name="_Access" model="Model.Inventory"/>
            </div>
        }
    </div>
</div>

<script>
    function reloadPage(tab){
        setTabQueryParameter(tab);
        location.reload();
    }
    
    function setTabQueryParameter(tab){
        const url = new URL(window.location.href);
        url.searchParams.set('tabOpened', tab);
        history.replaceState(null, '', url.toString());
    }
</script>