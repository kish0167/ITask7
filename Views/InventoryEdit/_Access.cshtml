@using ITask7.ViewModels.UI
@model ITask7.ViewModels.Inventories.InventoryViewModel

@{
    var accessToolbarModel = new BulkActionToolbarViewModel
    {
        Actions = new()
        {
            new()
            {
                Name = "delete", Title = "Delete", Icon = "bi-trash-fill",
                ButtonClass = "btn-outline-danger", Endpoint = "/InventoryEdit/DeleteAccesses",
                IsSingle = false
            }
        }
    };
}

<div class="d-flex justify-content-between align-items-center mb-3">
    @if (!Model.IsPublic)
    {
        <h5 class="mb-0">Users with write access</h5>
    }
    else
    {
        <h5 class="mb-0">This inventory is public</h5>
    }
</div>

<div class="table-responsive @(Model.IsPublic ? "opacity-50" : "")" data-bulk-context="access" data-context-id="@Model.Id">
    @if (!Model.IsPublic)
    {
        <div class="d-flex justify-content-between align-items-center mb-2 px-2">
            <partial name="Components/BulkActionToolbar/Default" model="accessToolbarModel"/>
            <button class="btn btn-primary btn-sm h-75" data-bs-toggle="modal" data-bs-target="#addUserModal">
                <i class="bi bi-plus-lg me-1"></i>Add user
            </button>
        </div>
        <table class="table table-hover table-striped align-middle">
            <thead class="@(Model.IsPublic ? "table-dark" : "table-light")">
            <tr>
                <th style="width: 40px;">
                    <input class="form-check-input select-all"
                           type="checkbox">
                </th>
                <th>Username</th>
            </tr>
            </thead>
            <tbody id="userTableBody">
            @foreach (var user in Model.WriteAccessUsers)
            {
                <tr style="cursor: pointer;" data-user-id="@user.Id">
                    <td>
                        <input class="form-check-input selectable-item"
                               type="checkbox"
                               value="@user.Id">
                    </td>
                    <td>
                        <span class="fw-bold">@user.Email</span>
                    </td>
                </tr>
            }
            @if (!Model.WriteAccessUsers.Any())
            {
                <tr>
                    <td></td>
                    <td>
                        <span class="fw-bold">No users with write access</span>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
    else
    {
        <tr>
            <td colspan="7" class="text-center text-muted py-4">
                Make inventory non-public to assign contributors
            </td>
        </tr>
    }
    <script>
        // ==================== TOOLBAR REQS ====================
    
        const context = document.currentScript.closest('[data-bulk-context]') || document
        context.addEventListener('bulkActionSuccess', function(e) {
            const { action, ids } = e.detail; 
            handleActionSuccess(action, ids);
        });
        
        // ==================== UI UPDATES ====================
        function handleActionSuccess(action, userIds) {  
            if (action === 'delete'){
                removeRows(userIds);
            }
        }    
        
        function removeRows(userIds) {
            userIds.forEach(id => {
                const row = document.querySelector(`tr[data-user-id="${id}"]`);
                if (row) row.remove();
            });
        }    
    </script>

    <!-- Add User Modal -->
    <div class="modal fade" id="addUserModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-sm modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add User</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3 position-relative">
                        <label for="usernameInput" class="form-label">Username</label>
                        <input type="text"
                               class="form-control"
                               id="usernameInput"
                               placeholder="Start typing username..."
                               autocomplete="off"
                               oninput="onUsernameInput(this.value)"
                               onfocus="onUsernameInput(this.value)"
                               onkeydown="onUsernameKeydown(event)">

                        <!-- Autocomplete dropdown -->
                        <ul class="dropdown-menu w-100 show"
                            id="autocompleteDropdown"
                            style="max-height: 200px; overflow-y: auto; display: none; position: absolute; top: 100%; left: 0; z-index: 1050;">
                            <!-- Items injected here -->
                        </ul>
                    </div>
                    <div id="selectedUserDisplay" class="small text-success fw-bold" style="display: none;"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary btn-sm" onclick="submitAddUser()">Add</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    async function submitAddUser() {
        const username = document.getElementById('usernameInput').value.trim();
        if (!username) {
            alert('Please enter a username');
            return;
        }
        
        const success = await postData(`/InventoryEdit/AddAccess?username=${username}`, '@Model.Id');
        if (!success) {
            alert("Couldn't grant access");
            return;
        }

        AddUserToTable(username, success)
        const modal = bootstrap.Modal.getInstance(document.getElementById('addUserModal'));
        modal.hide();
        document.getElementById('usernameInput').value = '';
    }
    
    let selectedUserId = null;
    let autocompleteItems = [];
    let highlightedIndex = -1;
    
    function onUsernameInput(value) {
        const dropdown = document.getElementById('autocompleteDropdown');
        const display = document.getElementById('selectedUserDisplay');
        
        if (selectedUserId) {
            selectedUserId = null;
            display.style.display = 'none';
            display.textContent = '';
        }
        
        if (value.length < 2) {
            dropdown.style.display = 'none';
            return;
        }
        
        clearTimeout(window.autocompleteTimeout);
        window.autocompleteTimeout = setTimeout(() => fetchUsers(value), 150);
    }
    
    async function fetchUsers(prefix) {
        try {
            const response = await fetch(`/Search/Users?prefix=${encodeURIComponent(prefix)}`);
            const users = await response.json();
            autocompleteItems = users;
            highlightedIndex = -1;
            renderDropdown(users);
        } catch (err) {
            console.error('Autocomplete fetch failed:', err);
        }
    }
    
    function renderDropdown(users) {
        const dropdown = document.getElementById('autocompleteDropdown');
        
        if (users.length === 0) {
            dropdown.innerHTML = '<li><span class="dropdown-item text-muted">No users found</span></li>';
            dropdown.style.display = 'block';
            return;
        }
        
        dropdown.innerHTML = users.map((user, index) => `
            <li>
                <a class="dropdown-item ${index === highlightedIndex ? 'active' : ''}" 
                   href="#"
                   onclick="selectUser('${user.id}', '${user.email}'); return false;"
                   data-index="${index}">
                    <div class="fw-bold">${highlightMatch(user.email)}</div>
                </a>
            </li>
        `).join('');
        
        dropdown.style.display = 'block';
    }
    
    function highlightMatch(email) {
        const input = document.getElementById('usernameInput').value;
        const regex = new RegExp(`(${escapeRegex(input)})`, 'gi');
        return email.replace(regex, '<mark>$1</mark>');
    }
    
    function escapeRegex(string) {
        return string.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    }
    
    function selectUser(id, email) {
        selectedUserId = id;
        document.getElementById('usernameInput').value = email;
        document.getElementById('autocompleteDropdown').style.display = 'none';
    }
    
    function onUsernameKeydown(event) {
        const dropdown = document.getElementById('autocompleteDropdown');
        if (dropdown.style.display === 'none') return;
        
        if (event.key === 'ArrowDown') {
            event.preventDefault();
            highlightedIndex = Math.min(highlightedIndex + 1, autocompleteItems.length - 1);
            updateHighlight();
        } else if (event.key === 'ArrowUp') {
            event.preventDefault();
            highlightedIndex = Math.max(highlightedIndex - 1, 0);
            updateHighlight();
        } else if (event.key === 'Enter') {
            event.preventDefault();
            if (highlightedIndex >= 0 && autocompleteItems[highlightedIndex]) {
                const user = autocompleteItems[highlightedIndex];
                selectUser(user.id, user.email);
            }
        } else if (event.key === 'Escape') {
            dropdown.style.display = 'none';
        }
    }
    
    function updateHighlight() {
        const items = document.querySelectorAll('#autocompleteDropdown .dropdown-item');
        items.forEach((item, idx) => {
            item.classList.toggle('active', idx === highlightedIndex);
        });
        if (items[highlightedIndex]) {
            items[highlightedIndex].scrollIntoView({ block: 'nearest' });
        }
    }
    
    document.addEventListener('click', function(e) {
        const container = document.getElementById('usernameInput')?.closest('.position-relative');
        if (container && !container.contains(e.target)) {
            document.getElementById('autocompleteDropdown').style.display = 'none';
        }
    });

    function resetModal() {
        document.getElementById('usernameInput').value = '';
        document.getElementById('selectedUserDisplay').style.display = 'none';
        document.getElementById('autocompleteDropdown').style.display = 'none';
        selectedUserId = null;
    }
    
    //------------- UI UPDATE ------------
    
    function AddUserToTable(username, id){
        const tb = document.getElementById('userTableBody');
        const rowHtml = `
                <tr onclick="toggleItem(this)" style="cursor: pointer;" data-user-id="${id}">
                    <td onclick="event.stopPropagation()">
                        <input class="form-check-input selectable-item"
                               type="checkbox"
                               value="${id}"
                               data-user-id="${id}"
                               onchange="toggleItemHighlight(this)">
                    </td>
                    <td>
                        <span class="fw-bold">${username}</span>
                    </td>
                </tr>
            `;
        tb.insertAdjacentHTML('beforeend', rowHtml);
    }
</script>