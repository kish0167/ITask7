@using ITask7.ViewModels.UI
@model ITask7.ViewModels.Inventories.InventoryViewModel

@{
    var toolbarModel = new BulkActionToolbarViewModel
    {
        Actions = new()
        {
            new()
            {
                Name = "delete", Title = "Delete", Icon = "bi-trash-fill",
                ButtonClass = "btn-danger", Endpoint = "/InventoryEdit/DeleteAccesses" // TODO!!!
            }
        }
    };
}

<div class="d-flex justify-content-between align-items-center mb-3">
    @if (!Model.IsPublic)
    {
        <h5 class="mb-0">Users with write access</h5>
        <button class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>Add user
        </button>
    }
    else
    {
        <h5 class="mb-0">This inventory is public</h5>
    }
</div>

<div class="table-responsive @(Model.IsPublic ? "opacity-50" : "")" data-bulk-context="access">
    @if (!Model.IsPublic)
    {
        <partial name="Components/BulkActionToolbar/Default" model="toolbarModel"/>
        <table class="table table-hover table-striped align-middle @(Model.IsPublic ? "table-secondary" : "")">
            <thead class="@(Model.IsPublic ? "table-dark" : "table-light")">
            <tr>
                <th style="width: 40px;">
                    <input class="form-check-input"
                           type="checkbox"
                           id="selectAll"
                           onclick="toggleSelectAll()">
                </th>
                <th>Username</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var user in Model.WriteAccessUsers)
            {
                <tr onclick="toggleItem(this)" style="cursor: pointer;" data-user-id="@user.Id">
                    <td onclick="event.stopPropagation()">
                        <input class="form-check-input selectable-item"
                               type="checkbox"
                               value="@user.Id"
                               data-user-id="@user.Id"
                               onchange="toggleItemHighlight(this)"></td>
                    <td>
                        <span class="fw-bold">@user.Email</span>
                    </td>
                </tr>
            }
            @if (!Model.WriteAccessUsers.Any())
            {
                <tr>
                    <td>
                        <span class="fw-bold">No users with write access</span>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
    else
    {
        <tr>
            <td colspan="7" class="text-center text-muted py-4">
                Make inventory non-public to assign contributors
            </td>
        </tr>
    }
    <script>
        // ==================== TOOLBAR REQS ====================
    
        const context = document.currentScript.closest('[data-bulk-context]') || document
        context.addEventListener('bulkActionSuccess', function(e) {
            const { action, ids } = e.detail; 
            handleActionSuccess(action, ids);
        });
        
        // ==================== UI UPDATES ====================
        function handleActionSuccess(action, userIds) {
            alert('Success!');
                
            if (action === 'delete'){
                removeRows(userIds);
            }
        }    
        
        function removeRows(userIds) {
            userIds.forEach(id => {
                const row = document.querySelector(`tr[data-user-id="${id}"]`);
                if (row) row.remove();
            });
        }    
    </script>
</div>

<script>
    
</script>

