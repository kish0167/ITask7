@using ITask7.Models.CustomId
@using Microsoft.AspNetCore.Mvc.TagHelpers
@model ITask7.Models.CustomId.IdElement

<div class="list-group-item element-row d-flex align-items-center gap-2 border-0 border-bottom">
    <div class="drag-handle px-2">
        <i class="bi bi-grip-vertical fs-4"></i>
    </div>

    <select class="form-select type-select w-auto" onchange="updateType(this)" name="Type">
        @foreach (IdElementType type in Enum.GetValues<IdElementType>())
        {
            <option value="@((int)type)" selected="@(Model.Type == type)">@type</option>
        }
    </select>

    <div class="flex-grow-1">
        <input type="text" class="form-control value-input @(Model.IsEditableFormat ? "" : "bg-body-tertiary text-muted")"
               placeholder="@(Model.IsEditableFormat ? "Format string" : "")"
               value="@Model.Format"
               @(Model.IsEditableFormat ? "" : "readonly")
               oninput="validateSchema()" name="Value"/>
    </div>

    <!--
    <div class="flex-grow-1">
        <input type="text" class="form-control value-input"
               placeholder="Format string"
               value="@Model.Format"
               oninput="validateSchema()" name="Value"/>
    </div>
    -->

    <button type="button" class="btn btn-link text-danger p-0" onclick="this.closest('.element-row').remove(); validateSchema();">
        <i class="bi bi-x-circle"></i>
    </button>
</div>

<script>
    function updateType(select) {
        const element = select.parentElement;
        const valueInput = element.querySelector('.value-input');
        const value = parseInt(select.value);
        const isBlocked = [3, 4, 7].includes(value);
    
        if (isBlocked) {
            valueInput.value = "";
            valueInput.placeholder = "";
            valueInput.readOnly = true;
            valueInput.classList.add('bg-body-tertiary', 'text-muted');
        } else {
            valueInput.placeholder = "Format string";
            valueInput.readOnly = false;
            valueInput.classList.remove('bg-body-tertiary', 'text-muted');
        }
       
        validateSchema();
    }
</script>