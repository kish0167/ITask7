@using ITask7.ViewModels.Inventories
@using ITask7.ViewModels.UI
@using ITask7.Models.Inventories
@model ITask7.ViewModels.Inventories.InventoryViewModel

@{
    var fieldsToolbarModel = new BulkActionToolbarViewModel
    {
        Actions = new()
        {
            new()
            {
                Name = "delete", Title = "Delete", Icon = "bi-trash-fill",
                ButtonClass = "btn-outline-danger", Endpoint = "/InventoryEdit/DeleteItems",
                IsSingle = false
            },
            new()
            {
                Name = "edit", Title = "Edit", Icon = "bi bi-pencil",
                ButtonClass = "btn-outline-primary", Endpoint = null,
                IsSingle = true
            }
        }
    };
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0">Inventory Items</h5>
</div>
<div class="card shadow-sm border-0 bg-body-tertiary" data-bulk-context="items" data-context-id="@Model.Id">
    <div class="d-flex justify-content-between align-items-center card-header bg-transparent border-bottom py-3">
        <partial name="Components/BulkActionToolbar/Default" model="fieldsToolbarModel"/>
        <button class="btn btn-primary btn-sm" onclick="window.location.href = 'ItemEdit?itemId=@Guid.Empty&inventoryId=@Model.Id';">
            <i class="bi bi-plus-lg me-1"></i>Add Item
        </button>
    </div>

    <table class="table table-hover mb-0 align-middle">
        <thead class="table">
        <tr class="text-uppercase small fw-bold text-muted">
            <th>
                <input class="form-check-input select-all" type="checkbox">
            </th>
            <th>Custom id</th>
            @foreach (FieldDefinitionViewModel field in Model.Fields)
            {
                if (!field.DisplayInTable) continue;
                <th data-bs-toggle="tooltip" data-bs-placement="top" title="@field.Description">
                    @field.Title
                </th>
            }
            <th>Created by</th>
            <th>Created at</th>
        </tr>
        </thead>
        <tbody>
        @if (Model.Items.Any())
        {
            @foreach (var item in Model.Items)
            {
                <tr style="cursor: pointer;" data-item-id="@item.Id">
                    <td>
                        <input class="form-check-input selectable-item"
                               type="checkbox"
                               value="@item.Id">
                    </td>
                    <td>
                        <a href="@Url.Action("Index", "ItemReadonly", new { itemId = item.Id })"
                           class="text-decoration-none fw-semibold link-primary"
                           onclick="event.stopPropagation();">
                            @item.CustomIdString()
                        </a>
                    </td>
                    @foreach (FieldDefinitionViewModel field in Model.Fields)
                    {
                        if (!field.DisplayInTable) continue;
                        <td>
                            @if (item.Fields.TryGetValue(field.Id, out FieldValueViewModel? value))
                            {
                                if (value.Type == FieldType.Document && value.DisplayValue != "no data")
                                {
                                    <a href="@value.DisplayValue" onclick="event.stopPropagation();">File</a>
                                }
                                else
                                {
                                    @value.DisplayValue
                                }
                            }
                        </td>
                    }
                    <td>@item.CreatedByUserName</td>
                    <td>@item.CreatedAtString</td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="@(Model.Fields.Count + 4)" class="text-center text-muted py-4">
                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                    No items found
                </td>
            </tr>
        }
        </tbody>
    </table>

    <script>
        // ==================== TOOLBAR REQS ====================
    
        const itemsTbContext = document.currentScript.closest('[data-bulk-context]') || document
        itemsTbContext.addEventListener('bulkActionSuccess', function(e) {
            const { action, ids } = e.detail; 
            handleItemsActionSuccess(action, ids);
        });
        
        // ==================== UI UPDATES ====================
        
        function handleItemsActionSuccess(action, ids){
            if (action === 'delete')
                removeItemsRows(ids);
            if (action === 'edit')
                window.location.href = `ItemEdit?itemId=${ids[0]}&inventoryId=@Model.Id`;
        }
        
        function removeItemsRows(itemsIds) {
            itemsIds.forEach(id => {
                const row = itemsTbContext.querySelector(`tr[data-item-id="${id}"]`);
                if (row) row.remove();
            });              
        }
    </script>
</div>