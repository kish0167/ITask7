@using ITask7.ViewModels.Inventories
@model ITask7.ViewModels.Inventories.InventoryViewModel

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0">Inventory Items</h5>
    <button class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i>Add Item
    </button>
</div>
<div class="table-responsive">
    <table class="table table-hover table-striped align-middle">
        <thead class="table-light">
        <tr>
            @foreach (FieldDefinitionViewModel field in Model.Fields)
            {
                if (!field.DisplayInTable) continue;
                <th data-bs-toggle="tooltip" data-bs-placement="top" title="@field.Description">
                    @field.Title
                </th>
            }
            <th>Id</th>
            <th>Created by</th>
            <th>Created at</th>
        </tr>
        </thead>
        <tbody>
        @if (Model.Items.Any())
        {
            @foreach (var item in Model.Items)
            {
                <tr>
                    @foreach (FieldDefinitionViewModel field in Model.Fields)
                    {
                        if (!field.DisplayInTable) continue;
                        <td>
                            @if (item.Fields.TryGetValue(field.Id, out FieldValueViewModel? value))
                            {
                                @value.DisplayValue
                            }
                        </td>
                    }
                    <td>@item.Id</td>
                    <td>@item.CreatedByUserName</td>
                    <td>@item.CreatedAtString</td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="6" class="text-center text-muted py-4">
                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                    No items found
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>