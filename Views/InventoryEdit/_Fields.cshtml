@using ITask7.ViewModels.UI
@using ITask7.Models.Inventories
@model ITask7.ViewModels.Inventories.InventoryViewModel

@{
    var fieldsToolbarModel = new BulkActionToolbarViewModel
    {
        Actions = new()
        {
            new()
            {
                Name = "delete", Title = "Delete", Icon = "bi-trash-fill",
                ButtonClass = "btn-outline-danger", Endpoint = "/InventoryEdit/DeleteFields",
                IsSingle = false
            },
            new()
            {
                Name = "edit", Title = "Edit", Icon = "bi bi-pencil",
                ButtonClass = "btn-outline-primary", Endpoint = null,
                IsSingle = true
            }
        }
    };
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0">Field Definitions</h5>
</div>

<div class="table-responsive" data-bulk-context="access" data-context-id="@Model.Id">
    <div class="d-flex justify-content-between align-items-center mb-2 px-2">
        <partial name="Components/BulkActionToolbar/Default" model="fieldsToolbarModel"/>
        <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addFieldModal">
            <i class="bi bi-plus-lg me-1"></i>Add Field
        </button>
    </div>

    <table class="table table-hover table-striped align-middle">
        <thead class="table-light">
        <tr>
            <th style="width: 40px;">
                <input class="form-check-input select-all"
                       type="checkbox">
            </th>
            <th style="width: 50px;">Order</th>
            <th>Title</th>
            <th>Description</th>
            <th>Type</th>
            <th class="text-center">Required</th>
            <th class="text-center">Display in Table</th>
        </tr>
        </thead>
        <tbody>
        @if (Model.Fields.Any())
        {
            @foreach (var field in Model.Fields.OrderBy(f => f.SortOrder))
            {
                <tr style="cursor: pointer;" data-field-id="@field.Id">
                    <td>
                        <input class="form-check-input selectable-item"
                               type="checkbox"
                               value="@field.Id">
                    </td>
                    <td>
                        <span class="badge bg-secondary">@field.SortOrder</span>
                    </td>
                    <td>
                        <span class="fw-bold">@field.Title</span>
                    </td>
                    <td>
                        <span class="text-muted text-truncate d-inline-block" style="max-width: 300px;" title="@field.Description">
                            @(string.IsNullOrEmpty(field.Description) ? "-" : field.Description)
                        </span>
                    </td>
                    <td>
                        <span class="badge bg-light text-dark border">
                            @field.Type
                        </span>
                    </td>
                    <td class="text-center">
                        @if (field.IsRequired)
                        {
                            <i class="bi bi-check-circle-fill text-success fs-5"></i>
                        }
                        else
                        {
                            <i class="bi bi-circle text-muted fs-5"></i>
                        }
                    </td>
                    <td class="text-center">
                        @if (field.DisplayInTable)
                        {
                            <i class="bi bi-table text-primary fs-5"></i>
                        }
                        else
                        {
                            <i class="bi bi-eye-slash text-muted fs-5"></i>
                        }
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="7" class="text-center text-muted py-4">
                    <i class="bi bi-layout-text-window-reverse fs-1 d-block mb-2"></i>
                    No field definitions found
                </td>
            </tr>
        }
        </tbody>
    </table>
    
    <script>
        // ==================== TOOLBAR REQS ====================
    
        const fieldsTbContext = document.currentScript.closest('[data-bulk-context]') || document
        fieldsTbContext.addEventListener('bulkActionSuccess', function(e) {
            const { action, ids } = e.detail; 
            handleFieldsActionSuccess(action, ids);
        });
        
        // ==================== UI UPDATES ====================
        
        function handleFieldsActionSuccess(action, ids){
            if (action === 'delete')
                removeFieldsRows(ids);
            if (action === 'edit'){}
                openEditFieldModal(ids[0])
        }

        async function openEditFieldModal(fieldId) {
            const row = fieldsTbContext.querySelector(`tr[data-field-id="${fieldId}"]`);
            if (!row) return;
            
            // Extract data from row
            const title = row.querySelector('td:nth-child(3) .fw-bold').textContent.trim();
            const description = row.querySelector('td:nth-child(4) span').textContent.trim();
            const typeText = row.querySelector('td:nth-child(5) .badge').textContent.trim();
            const sortOrder = row.querySelector('td:nth-child(2) .badge').textContent.trim();
            const isRequired = row.querySelector('td:nth-child(6) i').classList.contains('bi-check-circle-fill');
            const displayInTable = row.querySelector('td:nth-child(7) i').classList.contains('bi-table');
            
            // Populate form
            document.getElementById('editFieldId').value = fieldId;
            document.getElementById('editFieldTitle').value = title;
            document.getElementById('editFieldDescription').value = description === '-' ? '' : description;
            document.getElementById('editFieldTypeDisplay').value = typeText;
            document.getElementById('editFieldType').value = typeText;
            document.getElementById('editFieldSortOrderDisplay').value = sortOrder;
            document.getElementById('editFieldSortOrder').value = sortOrder;
            document.getElementById('editFieldDisplayInTable').checked = displayInTable;
            document.getElementById('editFieldIsRequiredDisplay').checked = isRequired;
            
            // Show modal
            const modal = new bootstrap.Modal(document.getElementById('editFieldModal'));
            modal.show();
        }    
        
        function removeFieldsRows(fieldIds) {
            fieldIds.forEach(id => {
                const row = fieldsTbContext.querySelector(`tr[data-field-id="${id}"]`);
                if (row) row.remove();
            });
        }            
    </script>
    
    <!-- Add Field Modal -->
    <div class="modal fade" id="addFieldModal" tabindex="-1" aria-labelledby="addFieldModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="addFieldModalLabel">Add New Field</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="addFieldForm">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label for="fieldTitle" class="form-label">Title <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="fieldTitle" name="Title" required maxlength="100">
                            </div>
                            <div class="col-md-6">
                                <label for="fieldType" class="form-label">Type <span class="text-danger">*</span></label>
                                <select class="form-select" id="fieldType" name="Type" required>
                                    @foreach (FieldType type in Enum.GetValues<FieldType>())
                                    {
                                        <option value="@((int)type)">@type.ToString()</option>
                                    }
                                </select>
                            </div>
                            <div class="col-12">
                                <label for="fieldDescription" class="form-label">Description</label>
                                <textarea class="form-control" id="fieldDescription" name="Description" rows="2" maxlength="500"></textarea>
                            </div>
                            <div class="col-md-4 d-flex align-items-center justify-content-center">
                                <div class="form-check form-switch mt-3">
                                    <input class="form-check-input" type="checkbox" id="fieldIsRequired" name="IsRequired" value="true">
                                    <label class="form-check-label" for="fieldIsRequired">Required Field</label>
                                </div>
                            </div>
                            <div class="col-md-4 d-flex align-items-center justify-content-center">
                                <div class="form-check form-switch mt-3">
                                    <input class="form-check-input" type="checkbox" id="fieldDisplayInTable" name="DisplayInTable" value="true" checked>
                                    <label class="form-check-label" for="fieldDisplayInTable">Display in Table</label>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" form="addFieldForm" class="btn btn-primary">Save Field</button>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Edit Field Modal -->
    <div class="modal fade" id="editFieldModal" tabindex="-1" aria-labelledby="editFieldModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="editFieldModalLabel">Edit Field</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="editFieldForm">
                        <input type="hidden" id="editFieldId" name="Id">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label for="editFieldTitle" class="form-label">Title <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="editFieldTitle" name="Title" required maxlength="100">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Type</label>
                                <input type="text" class="form-control" id="editFieldTypeDisplay" disabled readonly>
                                <input type="hidden" id="editFieldType" name="Type">
                            </div>
                            <div class="col-12">
                                <label for="editFieldDescription" class="form-label">Description</label>
                                <textarea class="form-control" id="editFieldDescription" name="Description" rows="2" maxlength="500"></textarea>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Sort Order</label>
                                <input type="text" class="form-control" id="editFieldSortOrderDisplay" disabled readonly>
                                <input type="hidden" id="editFieldSortOrder" name="SortOrder">
                            </div>
                            <div class="col-md-6 d-flex align-items-center justify-content-center">
                                <div class="form-check form-switch mt-3">
                                    <input class="form-check-input" type="checkbox" id="editFieldDisplayInTable" name="DisplayInTable" value="true">
                                    <label class="form-check-label" for="editFieldDisplayInTable">Display in Table</label>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="editFieldIsRequiredDisplay" disabled>
                                    <label class="form-check-label text-muted" for="editFieldIsRequiredDisplay">Required Field (read-only)</label>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" form="editFieldForm" class="btn btn-primary">Save Changes</button>
                </div>
            </div>
        </div>
    </div>
    
    
</div>

<script>
    document.getElementById('addFieldForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        
        const form = e.target;
        const submitBtn = form.closest('.modal-content').querySelector('button[type="submit"]');
        
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Saving...';
        
        const payload = {
            Id: '00000000-0000-0000-0000-000000000000',
            Title: document.getElementById('fieldTitle').value,
            Description: document.getElementById('fieldDescription').value,
            Type: parseInt(document.getElementById('fieldType').value),
            SortOrder: -1,
            DisplayInTable: document.getElementById('fieldDisplayInTable').checked,
            IsRequired: document.getElementById('fieldIsRequired').checked
        };

        try {
            const success = await postData(`/InventoryEdit/AddField?inventoryId=@Model.Id`, payload)
            
            if (success) {
                bootstrap.Modal.getInstance(document.getElementById('addFieldModal')).hide();
                form.reset();
            } else {
                const error = await response.text();
                alert('Error: ' + error);
            }
        } catch (err) {
            alert('Failed to save field');
        } finally {
            submitBtn.disabled = false;
            submitBtn.innerHTML = 'Save Field';
        }
    });
    
    document.getElementById('editFieldForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        
        const form = e.target;
        const submitBtn = form.closest('.modal-content').querySelector('button[type="submit"]');
        
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Saving...';
        
        const payload = {
            Id: document.getElementById('editFieldId').value,
            Title: document.getElementById('editFieldTitle').value,
            Description: document.getElementById('editFieldDescription').value,
            DisplayInTable: document.getElementById('editFieldDisplayInTable').checked,
        };
    
        try {
            const success = await postData(`/InventoryEdit/EditField?inventoryId=@Model.Id`, payload);
            if (success) {
                bootstrap.Modal.getInstance(document.getElementById('editFieldModal')).hide();
                location.reload();
            } else {
                alert('Error saving field');
            }
        } catch (err) {
            alert('Failed to save field');
        } finally {
            submitBtn.disabled = false;
            submitBtn.innerHTML = 'Save Changes';
        }
    });
</script>