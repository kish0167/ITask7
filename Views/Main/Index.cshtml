@model ITask7.ViewModels.Pages.MainPageViewModel

@{
    ViewBag.Title = "Dashboard";
    Layout = "_Layout";
}

<div class="container mt-4">
    <div class="row mb-5">
        <div class="col-12">
            <h1 class="display-5 mb-4">Inventory Dashboard</h1>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Latest Inventories</h5>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Name</th>
                                <th>Description</th>
                                <th>Creator</th>
                                <th>Updated</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.LatestInventories.Any())
                            {
                                foreach (var inventory in Model.LatestInventories)
                                {
                                    <tr>
                                        <td>
                                            <a href="@Url.Action("Index", "InventoryReadonly", new { inventoryId = inventory.Id })" 
                                               class="text-decoration-none fw-bold">
                                                @inventory.Name
                                            </a>
                                        </td>
                                        <td class="text-muted small">@inventory.Description</td>
                                        <td><span class="badge bg-light text-dark border">@inventory.CreatedBy</span></td>
                                        <td class="small text-secondary">@inventory.UpdatedAt.ToShortDateString()</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-4 text-muted">No inventories found.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">Top 5 Popular</h5>
                </div>
                <ul class="list-group list-group-flush">
                    @if (Model.PopularInventories.Any())
                    {
                        foreach (var popular in Model.PopularInventories)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <div class="text-truncate" style="max-width: 70%;">
                                    <a href="@Url.Action("Index", "InventoryReadonly", new { inventoryId = popular.Id })" 
                                       class="text-decoration-none text-dark">
                                        @popular.Name
                                    </a>
                                </div>
                                <span class="badge bg-primary rounded-pill">
                                    @popular.Items.Count Items
                                </span>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="list-group-item text-center text-muted">No data available.</li>
                    }
                </ul>
            </div>
        </div>
    </div>
</div>