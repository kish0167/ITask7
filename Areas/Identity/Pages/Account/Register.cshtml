@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <section class="p-4 p-md-5 border rounded-4 shadow-sm bg-body-tertiary">
                <h3 class="text-center fw-bold mb-4">Register with a service</h3>
                <hr class="my-4 opacity-25" />

                @if ((Model.ExternalLogins?.Count ?? 0) == 0)
                {
                    <div class="alert alert-info border-0 shadow-sm">
                        <p class="mb-0 text-center">
                            <i class="bi bi-info-circle me-2"></i>
                            No external authentication services configured.
                        </p>
                    </div>
                }
                else
                {
                    <div class="mx-auto" style="max-width: 350px;">
                        <p class="text-muted text-center small mb-4">Choose your preferred provider</p>
                        
                        <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                            <div class="vstack gap-3">
                                @foreach (var provider in Model.ExternalLogins!)
                                {
                                    <button type="submit"
                                            class="btn btn-outline-secondary btn-lg d-flex align-items-center justify-content-center py-2 shadow-sm transition-base"
                                            name="provider"
                                            value="@provider.Name"
                                            title="Log in using your @provider.DisplayName account">
                                        <i class="fab fa-@provider.Name.ToLower() me-3 fs-5"></i>
                                        <span class="fw-medium">Continue with @provider.DisplayName</span>
                                    </button>
                                }
                            </div>
                        </form>
                    </div>
                }
            </section>
        </div>
    </div>
</div>



@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}